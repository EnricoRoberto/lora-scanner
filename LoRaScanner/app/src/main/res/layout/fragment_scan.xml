<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!-- Header bar -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:background="@color/bg_surface"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Status indicator dot -->
        <View
            android:id="@+id/status_indicator"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/status_dot"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Disconnected"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/tv_packet_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 packets"
            android:textColor="@color/accent_cyan"
            android:textSize="12sp"
            android:fontFamily="monospace" />
    </LinearLayout>

    <!-- Stats strip -->
    <LinearLayout
        android:id="@+id/stats_strip"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/bg_card"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tv_avg_rssi"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Avg RSSI: —"
            android:textColor="@color/accent_cyan"
            android:textSize="11sp"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/tv_avg_snr"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Avg SNR: —"
            android:textColor="@color/accent_yellow"
            android:textSize="11sp"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/tv_nodes"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Nodes: 0"
            android:textColor="@color/accent_green"
            android:textSize="11sp"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/tv_ppm"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0 pkt/min"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:fontFamily="monospace" />
    </LinearLayout>

    <!-- Packet list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_packets"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/stats_strip"
        app:layout_constraintBottom_toTopOf="@id/button_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:listitem="@layout/item_packet" />

    <!-- Button bar -->
    <LinearLayout
        android:id="@+id/button_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="@color/bg_surface"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_scan"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="2"
            android:layout_marginEnd="8dp"
            android:text="Scan Devices"
            android:textColor="@color/bg_primary"
            android:textSize="13sp"
            app:backgroundTint="@color/accent_cyan"
            app:cornerRadius="6dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_simulate"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="▶ Demo"
            android:textColor="@color/accent_yellow"
            android:textSize="12sp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="@color/accent_yellow"
            app:cornerRadius="6dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_export"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="↑"
            android:textColor="@color/text_secondary"
            android:textSize="18sp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="@color/divider"
            app:cornerRadius="6dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
