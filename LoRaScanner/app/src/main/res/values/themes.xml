<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.LoRaScanner" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_cyan</item>
        <item name="colorPrimaryVariant">@color/bg_surface</item>
        <item name="colorOnPrimary">@color/bg_primary</item>
        <item name="colorSecondary">@color/accent_green</item>
        <item name="colorOnSecondary">@color/bg_primary</item>
        <item name="android:colorBackground">@color/bg_primary</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:statusBarColor">@color/bg_surface</item>
        <item name="android:navigationBarColor">@color/bg_surface</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="bottomNavigationStyle">@style/BottomNav</item>
    </style>

    <style name="BottomNav" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="android:background">@color/bg_surface</item>
        <item name="itemIconTint">@color/nav_item_color</item>
        <item name="itemTextColor">@color/nav_item_color</item>
        <item name="itemRippleColor">@color/accent_cyan</item>
    </style>
</resources>
